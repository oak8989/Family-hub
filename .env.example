# =============================================================================
# Family Hub - Environment Configuration
# =============================================================================
# Copy this file to .env: cp .env.example .env
# Then edit the values below
# =============================================================================

# JWT Secret Key - CHANGE THIS!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-key

# Application Port (default: 8001)
PORT=8001

# Database Name (default: family_hub)
DB_NAME=family_hub

# CORS Origins (default: * allows all)
# For production, set to your domain: https://family.yourdomain.com
CORS_ORIGINS=*
