# Family Hub Environment Configuration
# =====================================
# Copy this file to .env and customize the values

# =============================================================================
# Required Settings
# =============================================================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-key

# =============================================================================
# Optional Settings (defaults shown)
# =============================================================================

# Application port
PORT=8001

# Database name
DB_NAME=family_hub

# MongoDB URL (for external MongoDB, otherwise uses docker-compose MongoDB)
# MONGO_URL=mongodb://username:password@hostname:27017

# CORS Origins (comma-separated, or * for all)
CORS_ORIGINS=*

# =============================================================================
# Production Settings (for docker-compose.prod.yml)
# =============================================================================

# Your domain name (required for HTTPS)
# DOMAIN=family.yourdomain.com

# Email for Let's Encrypt SSL certificates
# ACME_EMAIL=your-email@example.com
